<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>InstaladorGeral</AssemblyName>
    <RootNamespace>InstaladorGeral</RootNamespace>
    <Version>0.1.0</Version>
    <FileVersion>0.1.0</FileVersion>
    <AssemblyVersion>0.1.0.0</AssemblyVersion>
    <UseAppHost Condition="'$(Configuration)'=='Debug'">false</UseAppHost>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\categories.json" />
    <EmbeddedResource Include="Resources\instalador.ico" />
  </ItemGroup>

</Project>
